{
  "name": "@flint/app",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "dev": "vite",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@flint/core": "workspace:*",
    "@flint/mcp": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.60",
    "@types/react-dom": "^18.2.19",
    "@types/node": "^20.11.0",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.4",
    "@monaco-editor/react": "^4.6.0",
    "@playwright/test": "^1.42.1",
    "typescript": "^5.3.3"
  }
}
