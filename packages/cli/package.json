{
  "name": "@flint/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "flint": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@flint/core": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "execa": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "tsx": "^4.7.0"
  }
}
